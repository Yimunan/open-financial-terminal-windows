# Open Financial Terminal — backend config. Copy to .env and edit as needed.
# Terminal-specific settings use the OFT_ prefix.

# Where the parquet price lake lives (relative to backend/ or absolute).
OFT_DATA_DIR=./data

# Directory of universe YAMLs (id/asset_class lists). Defaults to the sibling qhfi repo's
# config/instruments. Point this anywhere you keep universe definitions.
# OFT_UNIVERSE_DIR=../../quant-hedge-fund-incubator/config/instruments

# SQLite file for terminal-owned state (watchlists, holdings, alerts).
OFT_DB_PATH=./oft.sqlite

# Comma-separated CORS origins for the dev frontend.
OFT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Paper trading ---
# Starting cash for the local paper simulator (used when no Alpaca key is set).
# OFT_PAPER_INITIAL_CASH=100000
# Set these to route paper orders to Alpaca's hosted paper environment instead of the
# local simulator. Get free paper keys at https://alpaca.markets (paper account).
# OFT_ALPACA_API_KEY=
# OFT_ALPACA_API_SECRET=
# OFT_ALPACA_PAPER=true

# --- qhfi LLM stack (QHFI_ prefix, read by qhfi.core.config.Settings) ---
# The local vLLM auto-swap proxy. Defaults already match the user's stack.
# QHFI_LLM_BASE_URL=http://localhost:8001/v1
# QHFI_LLM_MODEL=gemma
